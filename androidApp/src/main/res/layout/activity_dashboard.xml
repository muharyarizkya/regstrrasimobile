<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Custom Header Bar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/dashboardToolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:contentInsetEnd="0dp"
                app:contentInsetLeft="0dp"
                app:contentInsetRight="0dp"
                app:contentInsetStart="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvToolbarProfile"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1.5dp"
                        app:strokeColor="#F1F5F9"
                        app:cardBackgroundColor="#F8FAFC"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_person"
                            android:padding="8dp"
                            android:contentDescription="Profile Icon"
                            app:tint="@color/accent" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvToolbarTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard"
                        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToolbarLogout"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logout"
                        android:textColor="#EF4444"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:rippleColor="#1AEF4444" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.appbar.MaterialToolbar>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Main Content Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Loading View -->
            <LinearLayout
                android:id="@+id/layoutDashboardLoading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/accent" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Memverifikasi Sesi JWT..."
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- Error View -->
            <LinearLayout
                android:id="@+id/layoutDashboardError"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Error Autentikasi"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textColor="#991B1B"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvDashboardErrorMsg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Token tidak valid atau sesi berakhir."
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDashboardErrorRetry"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Kembali ke Login"
                    android:backgroundTint="@color/accent"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Success Content -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scrollDashboardContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Welcome Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardBackgroundColor="#EFF6FF"
                        app:cardCornerRadius="16dp"
                        app:strokeColor="#DBEAFE"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Selamat Datang,"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="@color/text_secondary" />
                            <TextView
                                android:id="@+id/tvDashUserName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="John Doe"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                                android:textColor="@color/primary"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- STATE 1: Incomplete Profile (Form Lengkapi Data) -->
                    <LinearLayout
                        android:id="@+id/layoutProfileIncomplete"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="16dp"
                            app:strokeColor="@color/divider"
                            app:strokeWidth="1dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Lengkapi Data Diri"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="@color/accent"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:layout_marginBottom="16dp"
                                    android:text="Silakan lengkapi profil Anda."
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="@color/text_secondary" />

                                <!-- NIK Input -->
                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:hint="NIK"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp"
                                    app:counterEnabled="true"
                                    app:counterMaxLength="16"
                                    app:startIconDrawable="@android:drawable/ic_lock_lock">
                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/etDashNikInput"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="number"
                                        android:maxLength="16" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <!-- Provinsi Dropdown -->
                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:hint="Provinsi"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp">
                                    <AutoCompleteTextView
                                        android:id="@+id/spinnerDashProv"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="none" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <!-- Kabupaten Dropdown -->
                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/tilDashKab"
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:hint="Kabupaten / Kota"
                                    android:visibility="gone"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp">
                                    <AutoCompleteTextView
                                        android:id="@+id/spinnerDashKab"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="none" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <!-- Kecamatan Dropdown -->
                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/tilDashKec"
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:hint="Kecamatan"
                                    android:visibility="gone"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp">
                                    <AutoCompleteTextView
                                        android:id="@+id/spinnerDashKec"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="none" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <!-- Kelurahan Dropdown -->
                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/tilDashKel"
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:hint="Kelurahan / Desa"
                                    android:visibility="gone"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp">
                                    <AutoCompleteTextView
                                        android:id="@+id/spinnerDashKel"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="none" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <!-- Kode Pos -->
                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:hint="Kode Pos"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp">
                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/etDashZip"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:clickable="false"
                                        android:focusable="false"
                                        android:inputType="none" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <!-- Alamat Lengkap -->
                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="20dp"
                                    android:hint="Alamat Lengkap"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp">
                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/etDashAddressInput"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:lines="3" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <!-- Map Selection -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="Pilih Titik Lokasi Peta"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                    android:textColor="@color/accent"
                                    android:textStyle="bold" />

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="match_parent"
                                    android:layout_height="220dp"
                                    android:layout_marginBottom="8dp"
                                    app:cardCornerRadius="12dp"
                                    app:strokeColor="@color/divider"
                                    app:strokeWidth="1dp"
                                    app:cardElevation="0dp">
                                    <FrameLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent">
                                        <org.osmdroid.views.MapView
                                            android:id="@+id/dashMap"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent" />
                                        <ImageButton
                                            android:id="@+id/btnDashMyLocation"
                                            android:layout_width="40dp"
                                            android:layout_height="40dp"
                                            android:layout_gravity="end|bottom"
                                            android:layout_margin="12dp"
                                            android:background="@drawable/circle_button_bg"
                                            android:src="@drawable/ic_my_location"
                                            android:elevation="4dp"
                                            android:contentDescription="Lokasi Saya"
                                            app:tint="@color/accent" />
                                        <ImageButton
                                            android:id="@+id/btnDashFullscreenMap"
                                            android:layout_width="40dp"
                                            android:layout_height="40dp"
                                            android:layout_gravity="end|top"
                                            android:layout_margin="12dp"
                                            android:background="@drawable/circle_button_bg"
                                            android:src="@drawable/ic_fullscreen"
                                            android:contentDescription="Layar Penuh"
                                            android:elevation="4dp" />
                                    </FrameLayout>
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/tvDashCoords"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="end"
                                    android:text="Koordinat: Belum terdeteksi"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                    android:textColor="@color/text_secondary" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveProfile"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginBottom="24dp"
                            android:text="Simpan &amp; Lengkapi Data"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textStyle="bold"
                            android:backgroundTint="@color/accent"
                            app:cornerRadius="16dp" />
                    </LinearLayout>

                    <!-- STATE 2: Complete Profile (Detail Profil & JWT Debugger) -->
                    <LinearLayout
                        android:id="@+id/layoutProfileComplete"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- User Detail Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="16dp"
                            app:strokeColor="@color/divider"
                            app:strokeWidth="1dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Detail Profil Terdaftar"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:layout_marginVertical="12dp"
                                    android:background="@color/divider" />

                                <!-- NIK -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="NIK"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvDashNik"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="-"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />

                                <!-- Phone -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nomor HP"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvDashPhone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="-"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />

                                <!-- Region -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Provinsi"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvDashProvince"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="-"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Kabupaten"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvDashKabupaten"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="-"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Kecamatan"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvDashKecamatan"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="-"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Kelurahan"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvDashKelurahan"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="-"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />

                                <!-- Full Address -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Alamat Lengkap"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvDashAddress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:text="-"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:layout_marginBottom="12dp"
                                    android:background="@color/divider" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:text="Lokasi Terdaftar"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                    android:textColor="@color/accent"
                                    android:textStyle="bold" />

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="match_parent"
                                    android:layout_height="180dp"
                                    app:cardCornerRadius="12dp"
                                    app:strokeColor="@color/divider"
                                    app:strokeWidth="1dp"
                                    app:cardElevation="0dp">
                                    <org.osmdroid.views.MapView
                                        android:id="@+id/dashMapComplete"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent" />
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>

        <!-- Space for Bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
